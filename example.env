# ── Telegram ──────────────────────────────────────────────────────────────────
TELEGRAM_TOKEN=sike!

# ── whisper-server process ────────────────────────────────────────────────────
# Path to the whisper-server binary (built via 'make whisper-server').
WHISPER_SERVER_BIN=./bin/whisper-server

# Host and port the managed whisper-server listens on.
# Change the port if 8080 is already in use.
WHISPER_SERVER_HOST=127.0.0.1
WHISPER_SERVER_PORT=8080

# ── Inference options ─────────────────────────────────────────────────────────
# Path to the GGML model file.  Candidates:
#   models/ggml-large-v3-turbo-q5_0.bin  574 MB  near large-v3 quality, medium speed  ← default
#   models/ggml-medium-q8_0.bin          786 MB  medium, near-lossless Q8
#   models/ggml-medium-q5_0.bin          515 MB  medium, slight quality loss, fastest
WHISPER_MODEL=models/ggml-large-v3-turbo-q5_0.bin

# Number of CPU threads for inference.
# On i5-8250U (4 physical / 8 logical): 4 physical cores is optimal —
# hyperthreading adds ~22% latency on this memory-bandwidth-bound workload.
WHISPER_THREADS=4

# Beam search width.  5 matches Python openai-whisper default.
# Reduce to 1 (greedy) for a ~20% speed gain at the cost of accuracy.
WHISPER_BEAM_SIZE=5

# Language passed to whisper.  'auto' detects per clip.
# Set to 'es' or 'en' etc. to skip language detection and save a few tokens.
WHISPER_LANGUAGE=auto

# Enable flash attention in the decoder (speeds up attention computation).
# Set to 'true' once confirmed working with your whisper-server build.
WHISPER_FLASH_ATTN=false

# Per-request HTTP timeout in seconds.  Long clips on slow hardware can take
# several minutes; 600 s (10 min) is a safe ceiling for the i5-8250U.
WHISPER_TIMEOUT_SECS=600

# ── Voice Activity Detection ──────────────────────────────────────────────────
# VAD strips silence from the audio before it reaches the Whisper encoder,
# which can significantly reduce inference time for voice notes with pauses.
# Requires the Silero VAD model (download via 'make vad-model').
WHISPER_VAD=false
WHISPER_VAD_MODEL=models/ggml-silero-v6.2.0.bin

# ── Diagnostics ───────────────────────────────────────────────────────────────
# Enable timing logs (download, queue wait, HTTP round-trip, total).
WHISKER_TIMINGS=false

# Enable verbose per-segment transcript logging (implies WHISKER_TIMINGS).
DETAILED_TRANSCRIPTION_LOGGING=false
